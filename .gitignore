sc/kodok_kodok/Move.lock
sc/hackathon/build/
sc/hackathon/Move.lock

# Deployment artifacts — contain deployer address, regenerate from deploy script
sc/deployments/*.json

# Vercel local config
.vercel/

# TypeScript
*.tsbuildinfo
