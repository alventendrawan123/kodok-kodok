# Dependencies
node_modules/

# Next.js build cache
.next/
out/

# Environment files — never commit real values
.env*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS metadata
.DS_Store
Thumbs.db

# Local AI assistant settings (machine-specific, not project code)
.claude/

